generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  email          String   @unique
  hashedPassword String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pets Pet[]

  @@map("users")
}

model Pet {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  species      String
  morph        String   @default("")
  birthDate    String
  acquiredDate String
  photo        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  weights   WeightRecord[]
  feedings  FeedingRecord[]
  sheds     ShedRecord[]
  documents PetDocument[]
  notes     NoteRecord[]

  @@map("pets")
}

model WeightRecord {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  date   String
  weight Float

  petId String @db.ObjectId
  pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@map("weight_records")
}

model FeedingRecord {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  date     String
  prey     String
  grams    Float
  accepted Boolean
  notes    String  @default("")

  petId String @db.ObjectId
  pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@map("feeding_records")
}

model ShedRecord {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  date    String
  quality String
  notes   String @default("")

  petId String @db.ObjectId
  pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@map("shed_records")
}

model PetDocument {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  type     String @default("PDF")
  date     String
  category String

  petId String @db.ObjectId
  pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@map("pet_documents")
}

model NoteRecord {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  date        String
  category    String
  title       String
  description String @default("")
  severity    String @default("low")

  petId String @db.ObjectId
  pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@map("note_records")
}
